{{- $out := slice -}}
{{- range .Site.RegularPages -}}
  {{- if ne .Section "server-info" -}}
    {{- $server := .Params.server | default "" -}}
    {{- /* category: prefer the page's `categories` tag, else its section
         (covers still-nested shops, whose section is the category) */ -}}
    {{- $sec := (partial "category.html" .).title | default "" -}}
    {{- with .CurrentSection }}{{ if and (not $sec) .Title }}{{ $sec = .LinkTitle }}{{ end }}{{ end -}}
    {{- $coord := "" -}}
    {{- with .Params.loc }}{{ $coord = . }}{{ end -}}
    {{- with .Params.infobox }}{{ with .Coordinates }}{{ $coord = . }}{{ end }}{{ end -}}
    {{- $s := lower (printf "%s %s %s %s %s" .Title $server $sec $coord (.Params.owners | default "")) -}}
    {{- $out = $out | append (dict
        "title" .Title
        "url" .RelPermalink
        "category" $sec
        "season" $server
        "coord" $coord
        "s" $s) -}}
  {{- end -}}
{{- end -}}
{{- $out | jsonify -}}
